{
  "name": "samsung-device-helper-agent",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.6.0",
  "repository": "git@github.com:kulcsarrudolf/samsung-device-helper-agent.git",
  "author": "kulcsarrudolf <kulcsarrudolf@gmail.com>",
  "license": "MIT",
  "scripts": {
    "scrape": "tsx src/scraper.ts",
    "compare": "tsx src/compare.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn typecheck && yarn lint && yarn format:check"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^22.13.1",
    "samsung-device-helper": "^0.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
